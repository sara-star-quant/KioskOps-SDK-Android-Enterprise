<?xml version="1.0" encoding="utf-8"?>
<!-- WCAG 2.1 AA: Semantic structure, content descriptions, 48dp touch targets, contrast -->
<ScrollView
  xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:padding="16dp">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Header -->
    <TextView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:text="@string/title_data_rights"
      android:textSize="24sp"
      android:textColor="#212121"
      android:accessibilityHeading="true"
      android:importantForAccessibility="yes"
      android:layout_marginBottom="16dp" />

    <!-- User ID input section -->
    <TextView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:text="@string/section_user_id"
      android:textSize="18sp"
      android:textColor="#212121"
      android:accessibilityHeading="true"
      android:layout_marginBottom="8dp" />

    <EditText
      android:id="@+id/inputUserId"
      android:layout_width="match_parent"
      android:layout_height="48dp"
      android:minHeight="48dp"
      android:inputType="text"
      android:text="user-001"
      android:hint="@string/hint_user_id"
      android:contentDescription="@string/cd_user_id_input"
      android:layout_marginBottom="16dp" />

    <!-- Actions section -->
    <TextView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:text="@string/section_data_actions"
      android:textSize="18sp"
      android:textColor="#212121"
      android:accessibilityHeading="true"
      android:layout_marginBottom="8dp" />

    <Button
      android:id="@+id/btnEnqueueAsUser"
      android:layout_width="match_parent"
      android:layout_height="48dp"
      android:minHeight="48dp"
      android:text="@string/btn_enqueue_as_user"
      android:contentDescription="@string/cd_enqueue_as_user"
      android:layout_marginBottom="8dp" />

    <Button
      android:id="@+id/btnExportUserData"
      android:layout_width="match_parent"
      android:layout_height="48dp"
      android:minHeight="48dp"
      android:text="@string/btn_export_user_data"
      android:contentDescription="@string/cd_export_user_data"
      android:layout_marginBottom="8dp" />

    <Button
      android:id="@+id/btnDeleteUserData"
      android:layout_width="match_parent"
      android:layout_height="48dp"
      android:minHeight="48dp"
      android:text="@string/btn_delete_user_data"
      android:contentDescription="@string/cd_delete_user_data"
      android:layout_marginBottom="8dp" />

    <Button
      android:id="@+id/btnWipeAllData"
      android:layout_width="match_parent"
      android:layout_height="48dp"
      android:minHeight="48dp"
      android:text="@string/btn_wipe_all_data"
      android:contentDescription="@string/cd_wipe_all_data"
      android:layout_marginBottom="16dp" />

    <!-- Result section -->
    <TextView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:text="@string/section_result"
      android:textSize="18sp"
      android:textColor="#212121"
      android:accessibilityHeading="true"
      android:layout_marginBottom="8dp" />

    <TextView
      android:id="@+id/resultText"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:textSize="14sp"
      android:textColor="#424242"
      android:importantForAccessibility="yes"
      android:accessibilityLiveRegion="polite"
      android:layout_marginBottom="16dp" />

  </LinearLayout>
</ScrollView>
