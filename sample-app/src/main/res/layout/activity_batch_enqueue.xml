<?xml version="1.0" encoding="utf-8"?>
<!-- WCAG 2.1 AA: Semantic structure, content descriptions, 48dp touch targets, contrast -->
<ScrollView
  xmlns:android="http://schemas.android.com/apk/res/android"
  android:layout_width="match_parent"
  android:layout_height="match_parent"
  android:padding="16dp">

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <!-- Header -->
    <TextView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:text="@string/title_batch_enqueue"
      android:textSize="24sp"
      android:textColor="#212121"
      android:accessibilityHeading="true"
      android:importantForAccessibility="yes"
      android:layout_marginBottom="16dp" />

    <!-- Description -->
    <TextView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:text="@string/batch_description"
      android:textSize="14sp"
      android:textColor="#424242"
      android:layout_marginBottom="16dp" />

    <!-- Batch configuration section -->
    <TextView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:text="@string/section_batch_config"
      android:textSize="18sp"
      android:textColor="#212121"
      android:accessibilityHeading="true"
      android:layout_marginBottom="8dp" />

    <EditText
      android:id="@+id/inputBatchSize"
      android:layout_width="match_parent"
      android:layout_height="48dp"
      android:minHeight="48dp"
      android:inputType="number"
      android:text="100"
      android:hint="@string/hint_batch_size"
      android:contentDescription="@string/cd_batch_size_input"
      android:layout_marginBottom="8dp" />

    <Button
      android:id="@+id/btnStartBatch"
      android:layout_width="match_parent"
      android:layout_height="48dp"
      android:minHeight="48dp"
      android:text="@string/btn_start_batch"
      android:contentDescription="@string/cd_start_batch"
      android:layout_marginBottom="16dp" />

    <!-- Progress section -->
    <TextView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:text="@string/section_batch_progress"
      android:textSize="18sp"
      android:textColor="#212121"
      android:accessibilityHeading="true"
      android:layout_marginBottom="8dp" />

    <TextView
      android:id="@+id/progressText"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:textSize="14sp"
      android:textColor="#424242"
      android:importantForAccessibility="yes"
      android:accessibilityLiveRegion="polite"
      android:layout_marginBottom="8dp" />

    <TextView
      android:id="@+id/queueDepthText"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:textSize="14sp"
      android:textColor="#424242"
      android:contentDescription="@string/cd_queue_status"
      android:layout_marginBottom="16dp" />

    <!-- Errors section -->
    <TextView
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:text="@string/section_batch_errors"
      android:textSize="18sp"
      android:textColor="#212121"
      android:accessibilityHeading="true"
      android:layout_marginBottom="8dp" />

    <TextView
      android:id="@+id/errorText"
      android:layout_width="match_parent"
      android:layout_height="wrap_content"
      android:textSize="14sp"
      android:textColor="#424242"
      android:importantForAccessibility="yes"
      android:accessibilityLiveRegion="polite"
      android:layout_marginBottom="16dp" />

  </LinearLayout>
</ScrollView>
